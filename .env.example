# Supabase (required for web app)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-anon-key

# OAuth redirect is fixed in code to https://starsvs.com (see src/supabase.js).
# In Supabase Dashboard: Authentication → URL Configuration, set:
#   Site URL = https://starsvs.com
#   Redirect URLs = https://starsvs.com, https://starsvs.com/**
# Do not use localhost here or OAuth will redirect to localhost after sign-in.
