# Supabase (required for web app)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=your-anon-key

# OAuth redirect is fixed in code to https://starpros.app (see src/supabase.js).
# Custom Supabase API/auth domain (if used): https://auth.starpros.app — set VITE_SUPABASE_URL accordingly.
# In Supabase Dashboard: Authentication → URL Configuration, set:
#   Site URL = https://starpros.app
#   Redirect URLs must include OAuth callback for EVERY origin users hit, e.g.:
#   https://starpros.app/auth/callback
#   https://www.starpros.app/auth/callback
#   (or a wildcard that covers both, e.g. https://*.starpros.app/** if your provider allows it)
# Do not use localhost here or OAuth will redirect to localhost after sign-in.
